@page "/trucks/{Id:guid}"
@using AbbaFleet.Shared
@using AbbaFleet.Features.Trucks
@attribute [Authorize]
@rendermode InteractiveServer
@inject ITruckService TruckService
@inject IPermissionService PermissionService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<TruckDetail> Logger

<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<PageTitle>@(_truck?.PlateNumber ?? "Truck") — ABBA Fleet</PageTitle>

@if (_notFound)
{
    <MudText Typo="Typo.h5" Class="mb-4">Truck not found</MudText>
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => NavigationManager.NavigateTo(AppRoutes.Trucks))">
        Back to Trucks
    </MudButton>
}
else if (_truck is not null)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => NavigationManager.NavigateTo(AppRoutes.Trucks))" />
        <MudText Typo="Typo.h5">@_truck.PlateNumber</MudText>
        <MudChip T="string" Color="@(_truck.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
            @(_truck.IsActive ? "Active" : "Inactive")
        </MudChip>
        <MudChip T="string" Size="Size.Small"
                 Color="@(_truck.OwnershipType == OwnershipType.CompanyOwned ? Color.Primary : Color.Secondary)">
            @(_truck.OwnershipType == OwnershipType.CompanyOwned ? "Company Owned" : "Subcontracted")
        </MudChip>
        <MudSpacer />
        @if (!_isEditing)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Edit" OnClick="EnterEditMode">
                Edit
            </MudButton>
            @if (_truck.IsActive)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.LocalShipping" OnClick="ConfirmDeactivate">
                    Deactivate
                </MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.LocalShipping" OnClick="ConfirmReactivate">
                    Reactivate
                </MudButton>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Delete" OnClick="ConfirmDelete">
                Delete
            </MudButton>
        }
    </MudStack>

    @if (_isEditing)
    {
        <MudCard Class="mb-4">
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_form.PlateNumber" Label="Plate Number" Required="true"
                                      Counter="20" MaxLength="20" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_form.TruckModel" Label="Truck Model" Required="true"
                                      Counter="100" MaxLength="100" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="OwnershipType" @bind-Value="_form.OwnershipType" Label="Ownership Type" Required="true">
                            <MudSelectItem Value="OwnershipType.CompanyOwned">Company Owned</MudSelectItem>
                            <MudSelectItem Value="OwnershipType.Subcontracted">Subcontracted</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="Guid?" @bind-Value="_form.DriverId" Label="Assigned Driver" Clearable="true">
                            @foreach (var driver in _driverOptions)
                            {
                                <MudSelectItem T="Guid?" Value="@driver.Id">@driver.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_form.DateAcquired" Label="Date Acquired"
                                      InputType="InputType.Date" Required="true" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudCheckBox @bind-Value="_form.IsActive" Label="Active" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
            <MudCardActions>
                <MudSpacer />
                <MudButton OnClick="CancelEdit">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEdit">Save</MudButton>
            </MudCardActions>
        </MudCard>
    }
    else
    {
        <MudCard Class="mb-4">
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption">Plate Number</MudText>
                        <MudText>@_truck.PlateNumber</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption">Truck Model</MudText>
                        <MudText>@_truck.TruckModel</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption">Ownership Type</MudText>
                        <MudText>@(_truck.OwnershipType == OwnershipType.CompanyOwned ? "Company Owned" : "Subcontracted")</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption">Assigned Driver</MudText>
                        @if (_truck.DriverId.HasValue && _truck.DriverName is not null)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudLink Href="@AppRoutes.DriverDetailFor(_truck.DriverId.Value)">@_truck.DriverName</MudLink>
                                <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small"
                                               Color="Color.Primary" title="Change Driver"
                                               OnClick="OpenChangeDriverDialog" />
                                <MudIconButton Icon="@Icons.Material.Filled.PersonRemove" Size="Size.Small"
                                               Color="Color.Error" title="Remove Driver"
                                               OnClick="OpenRemoveDriverDialog" />
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudText>No driver assigned</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small"
                                               Color="Color.Primary" title="Assign Driver"
                                               OnClick="OpenAssignDriverDialog" />
                            </MudStack>
                        }
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption">Date Acquired</MudText>
                        <MudText>@_truck.DateAcquired.ToString("dd MMM yyyy")</MudText>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudText Typo="Typo.caption">Status</MudText>
                        <MudText>@(_truck.IsActive ? "Active" : "Inactive")</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption">Created</MudText>
                        <MudText>@_truck.CreatedAt.LocalDateTime.ToString("dd MMM yyyy h:mm tt")</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption">Last Updated</MudText>
                        <MudText>@_truck.UpdatedAt.LocalDateTime.ToString("dd MMM yyyy h:mm tt")</MudText>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    }

    <MudTabs Elevation="1" Rounded="true" Class="mt-4">
        <MudTabPanel Text="Investment Log">
            <MudText Class="pa-4" Typo="Typo.body2" Color="Color.Default">Coming soon</MudText>
        </MudTabPanel>
        <MudTabPanel Text="Notes">
            <NotePanel EntityType="NoteEntityType.Truck" EntityId="Id" />
        </MudTabPanel>
        <MudTabPanel Text="Files">
            <FilePanel EntityType="NoteEntityType.Truck" EntityId="Id" />
        </MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private TruckDetailDto? _truck;
    private bool _notFound;
    private bool _isEditing;
    private TruckForm _form = new();
    private List<LookupItem> _driverOptions = [];

    protected override async Task OnInitializedAsync()
    {
        if (!await PermissionService.HasAsync(Permission.ManageTrucks))
        {
            NavigationManager.NavigateTo(AppRoutes.Dashboard);
            return;
        }

        await LoadTruck();
    }

    private async Task LoadTruck()
    {
        _truck = await TruckService.GetByIdAsync(Id);
        _notFound = _truck is null;
    }

    private async Task EnterEditMode()
    {
        if (_truck is null)
        {
            return;
        }

        _driverOptions = [.. await TruckService.GetDriverOptionsAsync()];
        _form = new TruckForm
        {
            PlateNumber = _truck.PlateNumber,
            TruckModel = _truck.TruckModel,
            OwnershipType = _truck.OwnershipType,
            DriverId = _truck.DriverId,
            IsActive = _truck.IsActive,
            DateAcquired = _truck.DateAcquired.ToString("yyyy-MM-dd")
        };
        _isEditing = true;
    }

    private void CancelEdit() => _isEditing = false;

    private async Task SaveEdit()
    {
        if (string.IsNullOrWhiteSpace(_form.PlateNumber) || string.IsNullOrWhiteSpace(_form.TruckModel))
        {
            Snackbar.Add("Plate number and truck model are required.", Severity.Warning);
            return;
        }

        if (!DateOnly.TryParse(_form.DateAcquired, out var dateAcquired))
        {
            Snackbar.Add("Date acquired is required.", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<ReasonDialog>
        {
            { x => x.Title, "Reason for edit" },
            { x => x.ConfirmColor, Color.Primary }
        };

        var dialog = await DialogService.ShowAsync<ReasonDialog>("Edit Reason", parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled)
        {
            return;
        }

        var reason = dialogResult.Data as string;
        Logger.LogInformation("Truck {TruckId} edited. Reason: {Reason}", Id, reason);

        var request = new UpsertTruckRequest(
            _form.PlateNumber,
            _form.TruckModel,
            _form.OwnershipType,
            _form.DriverId,
            dateAcquired,
            _form.IsActive);

        var result = await TruckService.UpdateAsync(Id, request);

        if (!result.Succeeded)
        {
            Snackbar.Add(result.Error ?? "Failed to update truck.", Severity.Error);
            return;
        }

        Snackbar.Add("Truck updated.", Severity.Success);
        _isEditing = false;
        await LoadTruck();
    }

    private async Task OpenAssignDriverDialog()
    {
        _driverOptions = [.. await TruckService.GetDriverOptionsAsync()];

        var parameters = new DialogParameters<AssignDriverDialog>
        {
            { x => x.Title, "Assign Driver" },
            { x => x.DriverOptions, _driverOptions }
        };

        var dialog = await DialogService.ShowAsync<AssignDriverDialog>("Assign Driver", parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled)
        {
            return;
        }

        var assignment = dialogResult.Data as AssignDriverDialogResult;

        if (assignment is null)
        {
            return;
        }

        await PerformAssign(assignment.DriverId, assignment.Reason, force: false);
    }

    private async Task OpenChangeDriverDialog()
    {
        _driverOptions = [.. await TruckService.GetDriverOptionsAsync()];

        var parameters = new DialogParameters<AssignDriverDialog>
        {
            { x => x.Title, "Change Driver" },
            { x => x.DriverOptions, _driverOptions },
            { x => x.CurrentDriverId, _truck?.DriverId }
        };

        var dialog = await DialogService.ShowAsync<AssignDriverDialog>("Change Driver", parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled)
        {
            return;
        }

        var assignment = dialogResult.Data as AssignDriverDialogResult;

        if (assignment is null)
        {
            return;
        }

        await PerformAssign(assignment.DriverId, assignment.Reason, force: false);
    }

    private async Task PerformAssign(Guid driverId, string reason, bool force)
    {
        var result = await TruckService.AssignDriverAsync(Id, driverId, reason, force);

        if (!result.Succeeded)
        {
            if (result.Error?.StartsWith("CONFLICT:") == true)
            {
                var conflictPlate = result.Error["CONFLICT:".Length..];
                var confirmed = await ConfirmReassignment(driverId, conflictPlate, reason);

                if (confirmed)
                {
                    await PerformAssign(driverId, reason, force: true);
                }

                return;
            }

            Snackbar.Add(result.Error ?? "Failed to assign driver.", Severity.Error);
            return;
        }

        Logger.LogInformation("Driver assigned to truck {TruckId}. Reason: {Reason}", Id, reason);
        Snackbar.Add("Driver assigned.", Severity.Success);
        await LoadTruck();
    }

    private async Task<bool> ConfirmReassignment(Guid driverId, string conflictPlate, string reason)
    {
        var driverName = _driverOptions.FirstOrDefault(d => d.Id == driverId)?.Label ?? "This driver";

        var parameters = new DialogParameters<ConfirmReassignDialog>
        {
            { x => x.DriverName, driverName },
            { x => x.ConflictPlateNumber, conflictPlate }
        };

        var dialog = await DialogService.ShowAsync<ConfirmReassignDialog>("Reassign Driver?", parameters);
        var dialogResult = await dialog.Result;
        return dialogResult is not null && !dialogResult.Canceled;
    }

    private async Task OpenRemoveDriverDialog()
    {
        var parameters = new DialogParameters<ReasonDialog>
        {
            { x => x.Title, "Reason for removing driver" },
            { x => x.WarningText, "The driver will be unassigned from this truck." },
            { x => x.ConfirmColor, Color.Error }
        };

        var dialog = await DialogService.ShowAsync<ReasonDialog>("Remove Driver", parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled)
        {
            return;
        }

        var reason = dialogResult.Data as string;

        if (string.IsNullOrWhiteSpace(reason))
        {
            return;
        }

        var result = await TruckService.UnassignDriverAsync(Id, reason);

        if (!result.Succeeded)
        {
            Snackbar.Add(result.Error ?? "Failed to remove driver.", Severity.Error);
            return;
        }

        Logger.LogInformation("Driver removed from truck {TruckId}. Reason: {Reason}", Id, reason);
        Snackbar.Add("Driver removed.", Severity.Success);
        await LoadTruck();
    }

    private async Task ConfirmDelete()
    {
        var parameters = new DialogParameters<ReasonDialog>
        {
            { x => x.Title, "Reason for deletion" },
            { x => x.WarningText, "This action cannot be undone. The truck will be permanently deleted." },
            { x => x.ConfirmColor, Color.Error }
        };

        var dialog = await DialogService.ShowAsync<ReasonDialog>("Delete Truck", parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled)
        {
            return;
        }

        var reason = dialogResult.Data as string;
        Logger.LogInformation("Truck {TruckId} deleted. Reason: {Reason}", Id, reason);

        var result = await TruckService.DeleteAsync(Id);

        if (!result.Succeeded)
        {
            Snackbar.Add(result.Error ?? "Failed to delete truck.", Severity.Error);
            return;
        }

        Snackbar.Add("Truck deleted.", Severity.Success);
        NavigationManager.NavigateTo(AppRoutes.Trucks);
    }

    private async Task ConfirmDeactivate()
    {
        if (_truck is null)
        {
            return;
        }

        var parameters = new DialogParameters<ConfirmDeactivateDialog>
        {
            { x => x.Title, "Deactivate Truck" },
            { x => x.WarningText, "This truck will be deactivated and will no longer appear as available." },
            { x => x.ConfirmationLabel, "Plate Number" },
            { x => x.ExpectedValue, _truck.PlateNumber },
            { x => x.ConfirmColor, Color.Warning }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDeactivateDialog>("Deactivate Truck", parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled)
        {
            return;
        }

        var reason = dialogResult.Data as string;
        Logger.LogInformation("Truck {TruckId} deactivated. Reason: {Reason}", Id, reason);

        var result = await TruckService.DeactivateAsync(Id, reason ?? string.Empty);

        if (!result.Succeeded)
        {
            Snackbar.Add(result.Error ?? "Failed to deactivate truck.", Severity.Error);
            return;
        }

        Snackbar.Add("Truck deactivated.", Severity.Success);
        await LoadTruck();
    }

    private async Task ConfirmReactivate()
    {
        var parameters = new DialogParameters<ReasonDialog>
        {
            { x => x.Title, "Reactivate Truck" },
            { x => x.ConfirmColor, Color.Success }
        };

        var dialog = await DialogService.ShowAsync<ReasonDialog>("Reactivate Truck", parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled)
        {
            return;
        }

        var reason = dialogResult.Data as string;
        Logger.LogInformation("Truck {TruckId} reactivated. Reason: {Reason}", Id, reason);

        var result = await TruckService.ReactivateAsync(Id, reason ?? string.Empty);

        if (!result.Succeeded)
        {
            Snackbar.Add(result.Error ?? "Failed to reactivate truck.", Severity.Error);
            return;
        }

        Snackbar.Add("Truck reactivated.", Severity.Success);
        await LoadTruck();
    }

    private sealed class TruckForm
    {
        public string PlateNumber { get; set; } = string.Empty;
        public string TruckModel { get; set; } = string.Empty;
        public OwnershipType OwnershipType { get; set; } = OwnershipType.CompanyOwned;
        public Guid? DriverId { get; set; }
        public bool IsActive { get; set; } = true;
        public string DateAcquired { get; set; } = DateTime.Today.ToString("yyyy-MM-dd");
    }
}
