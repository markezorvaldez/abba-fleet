@using AbbaFleet.Features.Trucks
@using MudBlazor
@inject ITruckService TruckService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<InvestmentPanel> Logger

<MudStack Class="pa-4" Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h6">Investment Log</MudText>
        <MudSpacer />
        @if (!_loading)
        {
            <MudText Typo="Typo.subtitle1" Class="mr-4">
                <b>Total: R @_total.ToString("N2")</b>
            </MudText>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog">
            Add Entry
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_entries.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Default">No investment entries yet.</MudText>
    }
    else
    {
        <MudTable Items="_entries" Dense="true" Hover="true" Elevation="0">
            <HeaderContent>
                <MudTh>Date</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Description</MudTh>
                <MudTh Style="text-align:right">Amount</MudTh>
                <MudTh>Created By</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Date.ToString("dd MMM yyyy")</MudTd>
                <MudTd>
                    <MudChip T="string" Color="@GetTypeColor(context.Type)" Size="Size.Small">
                        @context.Type.ToString()
                    </MudChip>
                </MudTd>
                <MudTd>@context.Description</MudTd>
                <MudTd Style="text-align:right">R @context.Amount.ToString("N2")</MudTd>
                <MudTd>
                    @context.CreatedBy
                    <MudText Typo="Typo.caption" Color="Color.Default">
                        @context.CreatedAt.LocalDateTime.ToString("dd MMM yyyy")
                    </MudText>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudStack>

@code {
    [Parameter]
    public Guid TruckId { get; set; }

    private List<InvestmentDto> _entries = [];
    private decimal _total;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadEntries();
    }

    private async Task LoadEntries()
    {
        _loading = true;

        try
        {
            var (entries, total) = await TruckService.GetInvestmentsAsync(TruckId);
            _entries = [.. entries];
            _total = total;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load investment entries for truck {TruckId}", TruckId);
            Snackbar.Add("Failed to load investment entries.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenAddDialog()
    {
        var dialog = await DialogService.ShowAsync<AddInvestmentDialog>("Add Investment Entry");
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled)
        {
            return;
        }

        var request = (AddInvestmentRequest)dialogResult.Data!;
        var result = await TruckService.AddInvestmentAsync(TruckId, request);

        if (!result.Succeeded)
        {
            Snackbar.Add(result.Error ?? "Failed to add investment entry.", Severity.Error);
            return;
        }

        Snackbar.Add("Investment entry added.", Severity.Success);
        await LoadEntries();
    }

    private static Color GetTypeColor(InvestmentType type) => type switch
    {
        InvestmentType.Purchase => Color.Primary,
        InvestmentType.Repair => Color.Warning,
        InvestmentType.Upgrade => Color.Info,
        _ => Color.Default,
    };
}
