@inject IClientService ClientService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add Client</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error">@_error</MudAlert>
            }
            <MudTextField @bind-Value="_form.CompanyName" Label="Company Name" Required="true"
                          MaxLength="100" Counter="100"/>
            <MudTextField @bind-Value="_form.Description" Label="Description" Lines="2"
                          MaxLength="500" Counter="500"/>
            <MudTextField @bind-Value="_form.Address" Label="Address" MaxLength="200"/>
            <MudTextField @bind-Value="_form.TaxRate" Label="Tax Rate (%)" InputType="InputType.Number"/>
            <MudCheckBox @bind-Value="_form.IsActive" Label="Active"/>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(string.IsNullOrWhiteSpace(_form.CompanyName) || _form.TaxRate < 0 || _saving)"
                   OnClick="Submit">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private readonly FormModel _form = new();
    private string? _error;
    private bool _saving;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        _saving = true;
        _error = null;

        var request = new UpsertClientRequest(
            _form.CompanyName,
            string.IsNullOrWhiteSpace(_form.Description) ? null : _form.Description,
            string.IsNullOrWhiteSpace(_form.Address) ? null : _form.Address,
            _form.TaxRate,
            _form.IsActive);

        var result = await ClientService.CreateAsync(request);

        _saving = false;

        if (result.Succeeded)
        {
            MudDialog.Close(DialogResult.Ok(result.Value!.Id));
        }
        else
        {
            _error = result.Error;
        }
    }

    private sealed class FormModel
    {
        public string CompanyName { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? Address { get; set; }
        public decimal TaxRate { get; set; }
        public bool IsActive { get; set; } = true;
    }

}
