<Router AppAssembly="typeof(App).Assembly">
    <Found Context="routeData">
        <ErrorBoundary>
            <ChildContent>
                <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
                    <NotAuthorized>
                        <RedirectToLogin />
                    </NotAuthorized>
                </AuthorizeRouteView>
            </ChildContent>
            <ErrorContent>
                <MudAlert Severity="Severity.Error" Class="ma-4">
                    An unexpected error occurred. <MudLink Href="/" Underline="Underline.Always">Return to dashboard</MudLink>
                </MudAlert>
            </ErrorContent>
        </ErrorBoundary>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
