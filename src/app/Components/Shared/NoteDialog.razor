<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_title" Label="Title" Required="true"
                          Counter="200" MaxLength="200"
                          Placeholder="Note title..."/>
            <MudTextField @bind-Value="_body" Label="Body" Required="true" Lines="5"
                          Counter="4000" MaxLength="4000"
                          Placeholder="Note body..."/>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(string.IsNullOrWhiteSpace(_title) || string.IsNullOrWhiteSpace(_body))"
                   OnClick="Submit">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string Title { get; set; } = "Add Note";

    [Parameter]
    public string? NoteTitle { get; set; }

    [Parameter]
    public string? NoteBody { get; set; }

    private string _title = string.Empty;
    private string _body = string.Empty;

    protected override void OnInitialized()
    {
        _title = NoteTitle ?? string.Empty;
        _body = NoteBody ?? string.Empty;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Submit()
    {
        MudDialog.Close(DialogResult.Ok(new NoteDialogResult(_title, _body)));
    }

    public sealed record NoteDialogResult(string Title, string Body);

}
