<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Reassign Driver?</MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning">
            @DriverName is already assigned to truck <strong>@ConflictPlateNumber</strong>.
            Reassigning will remove them from that truck. Do you want to proceed?
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="Confirm">
            Reassign
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string DriverName { get; set; } = string.Empty;

    [Parameter]
    public string ConflictPlateNumber { get; set; } = string.Empty;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Confirm()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }

}
