@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudSelect T="Guid?" @bind-Value="_selectedDriverId" Label="Select Driver" Required="true">
                @foreach (var driver in DriverOptions)
                {
                    <MudSelectItem T="Guid?" Value="@driver.Id">@driver.Label</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_reason" Label="Reason" Required="true" Lines="3"
                          Placeholder="Please provide a reason..." />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(_selectedDriverId is null || string.IsNullOrWhiteSpace(_reason))"
                   OnClick="Submit">
            Confirm
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string Title { get; set; } = "Assign Driver";

    [Parameter]
    public IReadOnlyList<LookupItem> DriverOptions { get; set; } = [];

    [Parameter]
    public Guid? CurrentDriverId { get; set; }

    private Guid? _selectedDriverId;
    private string _reason = string.Empty;

    protected override void OnParametersSet()
    {
        _selectedDriverId = null;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(new AssignDriverDialogResult(_selectedDriverId!.Value, _reason)));
}
