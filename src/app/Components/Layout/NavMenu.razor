@using AbbaFleet.Shared
@inject IPermissionService PermissionService

<MudNavMenu Class="pa-2" Style="height: 100%;">
    <MudText Typo="Typo.h6" Class="pa-4" Style="color: white;">ABBA Fleet</MudText>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
    @foreach (var link in _navLinks.Where(l => l.Visible))
    {
        <MudNavLink Href="@link.Href" Icon="@link.Icon">@link.Label</MudNavLink>
    }
    <MudDivider />
    <MudNavLink Href="/account/logout" Icon="@Icons.Material.Filled.Logout">Log out</MudNavLink>
</MudNavMenu>

@code {
    private List<NavItem> _navLinks = [];

    protected override async Task OnInitializedAsync()
    {
        _navLinks =
        [
            new("/users", "Users", Icons.Material.Filled.People, await PermissionService.HasAsync(Permission.ManageUsers)),
            new("/drivers", "Drivers", Icons.Material.Filled.Badge, await PermissionService.HasAsync(Permission.ManageDrivers)),
            new("/trucks", "Trucks", Icons.Material.Filled.LocalShipping, await PermissionService.HasAsync(Permission.ManageTrucks)),
        ];
    }

    private sealed record NavItem(string Href, string Label, string Icon, bool Visible);
}
